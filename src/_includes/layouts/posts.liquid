---
layout: layouts/base
---

{% capture byline %}
{% if version_date %}
Last updated {{ version_date | date: "%e %B, %Y"}}, originally posted {{ date | date: "%e %B, %Y"}}
{% else %}
Posted {{ date | date: "%e %B, %Y"}}
{% endif %}
{% endcapture %}

{% if tag %}
  {% assign flourish_phrase = tag | tagPhrase %}
{% endif %}

{% render "partials/article"
          header: title,
          byline: byline,
          content: content,
          subscription: subscription,
          cta: cta,
          site: site,
          flourish: flourish_phrase %}
