<div class="[ gutter flow ]">
  <div>
    <h1 class="">{{ year }}</h1>
  </div>
  <div class="flow">
    {% for post in collection reversed %}
    <div>
      <div class="flow flow-space-xs">
        <h4><a href="{{ post.permalink }}">{{ post.title }}</a></h4>
        <p>
          <em>{{ post.date | date: "%e %b %Y" }}</em>
          {% for tag in post.tags %}
            <a href="/writing/{{ tag | toSlug }}/" class="[ category-pill ]" data-color="{{ tag | tagColorIndex }}">{{ tag | titleCaseTag }}</a>
          {% endfor %}
        </p>
        <p>{{ post.summary }}</p>
      </div>
    </div>
    {% endfor %}
  </div>
</div>